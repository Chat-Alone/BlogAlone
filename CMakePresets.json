{
  "version": 8,
  "configurePresets": [
    {
      "name": "windows-vs",
      "displayName": "Windows VS x64",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build-msvc",
      "environment": {
        "VCPKG_DOWNLOADS": "${sourceDir}/.vcpkg-cache/downloads",
        "X_VCPKG_REGISTRIES_CACHE": "${sourceDir}/.vcpkg-cache/registries",
        "VCPKG_DEFAULT_BINARY_CACHE": "${sourceDir}/.vcpkg-cache/bincache"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "C:/Program Files/Microsoft Visual Studio/18/Community/VC/vcpkg/scripts/buildsystems/vcpkg.cmake"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs-debug",
      "configurePreset": "windows-vs",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "windows-vs-debug",
      "configurePreset": "windows-vs",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
