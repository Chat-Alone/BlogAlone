{
  "listeners": [
    {
      "address": "127.0.0.1",
      "port": 8080,
      "https": false
    }
  ],
  "app": {
    "threads_num": 4,
    "run_as_daemon": false
  },
  "client_max_body_size": 6291456,
  "db_clients": [
    {
      "name": "default",
      "rdbms": "sqlite3",
      "filename": "/var/lib/blogalone/blogalone.db",
      "is_fast": false,
      "number_of_connections": 1
    }
  ],
  "plugins": [
    {
      "name": "blogalone::plugins::DatabaseMigrationPlugin",
      "dependencies": [],
      "config": {
        "database_path": "/var/lib/blogalone/blogalone.db",
        "migrations_dir": "migrations",
        "db_client": "default"
      }
    },
    {
      "name": "blogalone::plugins::UploadCleanupPlugin",
      "dependencies": [
        "blogalone::plugins::DatabaseMigrationPlugin"
      ],
      "config": {}
    },
    {
      "name": "blogalone::plugins::SessionCleanupPlugin",
      "dependencies": [
        "blogalone::plugins::DatabaseMigrationPlugin"
      ],
      "config": {}
    }
  ],
  "custom_config": {
    "trusted_proxies": [
      "127.0.0.1"
    ],
    "web_root": "/opt/blogalone/web",
    "uploads_root": "/var/lib/blogalone/uploads",
    "session_ttl_seconds": 1209600,
    "upload_max_file_size": 5242880,
    "upload_max_daily_uploads": 100,
    "upload_max_dimension": 5792,
    "rate_limit_registration_max_requests": 5,
    "rate_limit_registration_window_seconds": 3600,
    "rate_limit_login_max_requests": 5,
    "rate_limit_login_window_seconds": 300,
    "rate_limit_upload_max_requests": 20,
    "rate_limit_upload_window_seconds": 60,
    "rate_limit_post_max_requests": 30,
    "rate_limit_post_window_seconds": 60,
    "orphan_upload_retention_seconds": 86400,
    "upload_cleanup_interval_seconds": 3600,
    "session_cleanup_interval_seconds": 3600,
    "password_opslimit": 3,
    "password_memlimit": 268435456
  }
}
